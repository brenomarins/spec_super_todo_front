			"SessionResponse": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"description": "Session ID (21-char nanoid)",
						"example": "V1StGXR8_Z5jdHi6B-myT",
						"readOnly": true
					},
					"taskId": {
						"type": "string",
						"description": "ID of the task this session belongs to; null for standalone break sessions",
						"example": "V1StGXR8_Z5jdHi6B-myT"
					},
					"startedAt": {
						"type": "string",
						"format": "date-time",
						"description": "Session start timestamp (ISO-8601)",
						"example": "2026-03-23T10:00:00Z",
						"readOnly": true
					},
					"completedAt": {
						"type": "string",
						"format": "date-time",
						"description": "Session end timestamp (ISO-8601); null if session is still open",
						"example": "2026-03-23T10:25:00Z",
						"readOnly": true
					},
					"type": {
						"type": "string",
						"description": "Session type: work, short_break, or long_break",
						"enum": [
							"work",
							"short_break",
							"long_break"
						],
						"example": "work"
					},
					"durationMinutes": {
						"type": "integer",
						"format": "int32",
						"description": "Planned duration in minutes (25 for work, 5 for short_break, 15 for long_break)",
						"example": 25,
						"readOnly": true
					},
					"isOpen": {
						"type": "integer",
						"format": "int32",
						"description": "Integer flag: 1 = session is running, 0 = session is closed (stored as int rather than boolean to match the DB column type)",
						"example": 1,
						"readOnly": true
					}
				}
			},
