				"properties": {
					"id": {
						"type": "string",
						"description": "Client-provided task ID (21-char nanoid); generated server-side if omitted",
						"example": "V1StGXR8_Z5jdHi6B-myT"
					},
					"title": {
						"type": "string",
						"description": "Task title",
						"example": "Write unit tests"
					},
					"description": {
						"type": "string",
						"description": "Task description",
						"example": "Cover the happy path and error cases"
					},
					"completed": {
						"type": "boolean",
						"description": "Whether the task starts as completed; defaults to false if omitted",
						"example": false
					},
					"parentId": {
						"type": "string",
						"description": "Parent task ID; null for root-level tasks",
						"example": "V1StGXR8_Z5jdHi6B-myT"
					},
					"order": {
						"type": "integer",
						"format": "int32",
						"description": "Display order; defaults to 0 if omitted",
						"example": 0
					},
					"tagIds": {
						"type": "array",
						"description": "Tag IDs to apply to the task",
						"example": [
							"tagId1"
						],
						"items": {
							"type": "string"
						}
					},
					"scheduledDay": {
						"type": "string",
						"format": "date",
						"description": "Scheduled date (ISO-8601)",
						"example": "2026-03-23"
					},
					"dueDate": {
						"type": "string",
						"format": "date",
						"description": "Due date (ISO-8601)",
						"example": "2026-03-30"
					}
				},
				"required": [
					"title"
				]
			},
			"ErrorResponse": {
